# Environment: dev | production
APP_ENV=dev

# Default organization id for local dev bearer tokens only (multi-tenant isolation)
DEFAULT_ORGANIZATION_ID=default

# HMAC secret for OAuth state (GitHub/Slack callbacks) — required in production
OAUTH_STATE_SECRET=

# Fernet key for encrypting integration tokens at rest — required in production
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Dev-only API tokens (leave empty / unset in production; rejected when APP_ENV=production)
ADMIN_TOKEN=
VIEWER_TOKEN=

# Firebase project ID 
FIREBASE_PROJECT_ID=your_firebase_project_id

# Database connection URL
DATABASE_URL=

# Path to Firebase service account credentials
SERVICE_FIREBASE=./service-firebase.json

# Deploy Firestore security rules: ./scripts/deploy-firestore-rules.sh
# Requires FIREBASE_PROJECT_ID (or project_id in SERVICE_FIREBASE JSON)

# Path to policies configuration file
POLICIES_FILE=./policies.yaml

CLAUDE_API_KEY=your_claude_token_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI-compatible provider settings
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=z-ai/glm4.7

# System copilot: auto | openai | gemini | claude
COPILOT_PROVIDER=auto
# COPILOT_TIMEOUT_SECONDS=60
# COPILOT_TRANSPORT_RETRIES=2
# COPILOT_RETRY_BACKOFF_SECONDS=1.0
# COPILOT_CIRCUIT_FAILURE_THRESHOLD=5
# COPILOT_CIRCUIT_RECOVERY_SECONDS=300
# COPILOT_DEFAULT_MONTHLY_REQUEST_LIMIT=200
# COPILOT_DEFAULT_MONTHLY_COST_CAP_USD=25
# COPILOT_DEFAULT_DAILY_REQUEST_LIMIT_PER_USER=50
# COPILOT_PLATFORM_MAX_MONTHLY_REQUEST_LIMIT=5000
# COPILOT_PLATFORM_MAX_MONTHLY_COST_CAP_USD=500
# COPILOT_ESTIMATED_COST_PER_REQUEST_USD=0.02
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GitHub integration (TrustFabric operator sets ONCE — not per customer)
# Register one OAuth App: https://github.com/settings/developers
# Callback URL defaults to {API_BASE_URL}/api/v1/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=   # optional; derived from API_BASE_URL when unset
FRONTEND_URL=http://localhost:3000

# Public API origin — used for OAuth callbacks, SAML ACS, and API docs
API_BASE_URL=http://localhost:8000

# Slack integration (TrustFabric operator sets ONCE — not per customer)
# https://api.slack.com/apps — redirect defaults to {API_BASE_URL}/api/v1/integrations/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=     # optional; derived from API_BASE_URL when unset

# AWS integration (cross-account IAM role)
AWS_EXTERNAL_ID=

# Figma: per-workspace personal access tokens are configured in Settings (encrypted at rest).
# Do not set a global Figma token in production.

# Rate limits (requests per minute, token-bucket per IP + user)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_EXPENSIVE_PER_MINUTE=10
RATE_LIMIT_AUTH_PER_MINUTE=20

# Background job queue (in-process worker; Firestore-backed job state)
JOB_QUEUE_MAX_CONCURRENT=2

# Idempotency key TTL for write endpoints (hours)
IDEMPOTENCY_TTL_HOURS=24

# Comma-separated allowed CORS origins (do NOT use * in production).
# In APP_ENV=dev, localhost / 127.0.0.1 / private LAN IPs (e.g. http://192.168.x.x:3000) are also allowed.
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
