# Environment: dev | production
APP_ENV=dev

# Admin token for privileged API access
ADMIN_TOKEN=your_admin_token_here

# Viewer token for read-only access
VIEWER_TOKEN=your_viewer_token_here

# Firebase project ID 
FIREBASE_PROJECT_ID=your_firebase_project_id

# Database connection URL
DATABASE_URL=

# Path to Firebase service account credentials
SERVICE_FIREBASE=./service-firebase.json

# Path to policies configuration file
POLICIES_FILE=./policies.yaml

CLAUDE_API_KEY=your_claude_token_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI-compatible provider settings
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=z-ai/glm4.7

# System copilot: auto | openai | gemini | claude
COPILOT_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GitHub integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
FRONTEND_URL=

# Slack integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=

# Comma-separated allowed CORS origins (do NOT use * in production)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
