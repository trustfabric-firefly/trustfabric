# Copy to .env.local and fill in values:
#   cp .env.local.example .env.local

# API (required for the UI to talk to FastAPI)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional: only used in dev stub mode (no Firebase web config) — same value as backend ADMIN_TOKEN if you want admin API calls
# NEXT_PUBLIC_DEV_ADMIN_TOKEN=your_admin_token_here

# Firebase web app config (Console → Project settings → Your apps → Web app).
# If NEXT_PUBLIC_FIREBASE_API_KEY is unset, the app uses a local dev user (no real login).
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
